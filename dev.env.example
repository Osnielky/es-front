# ===========================================
# DEV ENVIRONMENT VARIABLES
# ===========================================
# Copy this to dev.env and fill in your values
# These are used locally. In GCP, use Secret Manager.

# PostgreSQL (Cloud SQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Cloud SQL with Cloud Run: postgresql://postgres:PASSWORD@/esfront_dev?host=/cloudsql/es-cars-dev:us-east1:es-cars-dev-db
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@/esfront_dev?host=/cloudsql/es-cars-dev:us-east1:es-cars-dev-db"

# App URLs
NEXT_PUBLIC_SITE_URL="https://es-front-dev-XXXXXXXXXX-uc.a.run.app"

# Dealer Info
NEXT_PUBLIC_DEALER_NAME="E&S Car Sales"
NEXT_PUBLIC_DEALER_PHONE="+1 (941) 499-7415"
NEXT_PUBLIC_DEALER_ADDRESS="1029 Airport-Pulling Rd unit c 49 Naples FL 34104"

# Admin Auth (stored in Secret Manager for production)
ADMIN_EMAIL="admin@eandscars.com"
ADMIN_PASSWORD="CHANGE_THIS_SECURE_PASSWORD"
ADMIN_SESSION_SECRET="your-32-char-minimum-secret-key-here"

# Google Cloud Storage
GCS_BUCKET_NAME="es-cars-dev-images"
GCS_PROJECT_ID="es-cars-dev"

# Upload limits
MAX_UPLOAD_SIZE_MB="5"

# Environment
NODE_ENV="development"
